# ─── Python Bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
*.egg-info/
dist/
build/
.eggs/

# ─── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env/
ps1/

# ─── Trained Models (generated by running scripts/train_baseline.py) ───────────
models/*.pkl
models/*.pth
models/*.h5
models/*.pt
models/*.bin
!models/.gitkeep

# ─── Dataset Files (download from https://www.unb.ca/cic/datasets/nsl.html) ────
data/*.txt
data/*.csv
data/*.arff
data/*.json
data/*.gz
!data/.gitkeep

# ─── Experiment Outputs (generated by running scripts/) ───────────────────────
results/*.json
results/*.csv
results/*.png
results/*.pdf
!results/.gitkeep

# ─── Runtime Logs (written during dashboard / experiment execution) ────────────
logs/sessions/
logs/analytics/
logs/attacks/
logs/*.json
logs/*.log
logs/*.txt
logs/*.csv
*.log
!logs/.gitkeep

# ─── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/*
!.streamlit/config.toml

# ─── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Secrets and Environment Variables ────────────────────────────────────────
.env
*.env
secrets.toml

# ─── OS Generated Files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
*.code-workspace
